  "phase_tasks": [
    {
      "task_id": "wf_reminder_gate",
      "title": "Reminder gate phase for baseline verification",
      "owner_role": "e2e_mgr_rd_lead",
      "dependencies": [],
      "artifacts": [],
      "acceptance": ["Internal gating task released by E2E after reminder redispatch is observed."]
    },
    {
      "task_id": "wf_reminder_probe",
      "title": "Reminder probe phase validates idle reminder redispatch",
      "owner_role": "e2e_mgr_ui_designer",
      "dependencies": [],
      "artifacts": ["docs/e2e/workflow_reminder_probe.md"],
      "acceptance": ["Create a small reminder probe artifact and report completion after reminder-driven wake-up."]
    },
    {
      "task_id": "wf_plan_master",
      "title": "Plan Task: global plan, decomposition rules, and collaboration protocol",
      "owner_role": "e2e_mgr_rd_lead",
      "dependencies": ["wf_reminder_gate"],
      "artifacts": ["docs/plan/00_master_plan.md"],
      "acceptance": [
        "Define global plan and milestones for Android gesture recognition app.",
        "Define subtask creation standards (title/dependencies/acceptance/artifacts) with strict dependency order.",
        "Define reporting and discuss protocol across roles, with code-first delivery priority."
      ]
    },
    {
      "task_id": "wf_product_definition",
      "title": "Define product scope, target users, and MVP boundaries",
      "owner_role": "e2e_mgr_product_owner",
      "dependencies": ["wf_plan_master"],
      "artifacts": ["docs/product/01_product_scope.md"],
      "acceptance": [
        "Clarify target users and key scenarios.",
        "Define MVP features and out-of-scope items.",
        "Provide implementation-oriented MVP boundaries for Android code delivery."
      ]
    },
    {
      "task_id": "wf_interaction_design",
      "title": "Produce interaction flow and key journey decisions",
      "owner_role": "e2e_mgr_interaction_designer",
      "dependencies": ["wf_product_definition"],
      "artifacts": ["docs/ux/interaction/01_interaction_flow.md"],
      "acceptance": [
        "Cover end-to-end interaction flow and state transitions.",
        "Include gesture interaction feedback rules.",
        "Ensure interaction decisions can be directly mapped to Android implementation tasks."
      ]
    },
    {
      "task_id": "wf_ui_design",
      "title": "Produce UI specification and visual component constraints",
      "owner_role": "e2e_mgr_ui_designer",
      "dependencies": ["wf_interaction_design"],
      "artifacts": ["docs/ux/ui/01_ui_spec.md", "src/android/app/src/main/res/layout/activity_main.xml"],
      "acceptance": [
        "Define key screens and UI component rules.",
        "Define accessibility and visual consistency baseline.",
        "Provide UI specification that can be consumed by Android code implementation."
      ]
    },
    {
      "task_id": "wf_engineering_decomposition",
      "title": "RD lead decomposes engineering plan and ownership",
      "owner_role": "e2e_mgr_rd_lead",
      "dependencies": ["wf_product_definition", "wf_interaction_design", "wf_ui_design"],
      "artifacts": ["docs/engineering/01_dev_breakdown.md", "src/android/README.md"],
      "acceptance": [
        "Break down Android/ML/QA/Release work packages.",
        "Include dependency order and integration checkpoints.",
        "Define code package ownership and delivery order for src/android outputs."
      ]
    },
    {
      "task_id": "wf_engineering_execution",
      "title": "Execute Android implementation and integration contracts",
      "owner_role": "e2e_mgr_android_dev",
      "dependencies": ["wf_engineering_decomposition"],
      "artifacts": [
        "src/android/app/src/main/AndroidManifest.xml",
        "src/android/app/build.gradle",
        "src/android/app/src/main/java/com/gesturerecognition/MainActivity.kt",
        "app/integration/gesture_pipeline_contract.md"
      ],
      "acceptance": [
        "Deliver Android module structure and core source code under src/android.",
        "Define integration contract for gesture pipeline."
      ]
    },
    {
      "task_id": "wf_quality_release",
      "title": "Define quality validation and release runbook",
      "owner_role": "e2e_mgr_qa_engineer",
      "dependencies": ["wf_engineering_execution"],
      "artifacts": ["qa/01_test_plan.md", "release/01_release_runbook.md", "src/android/app/src/test"],
      "acceptance": [
        "Define test strategy and key acceptance tests for delivered source code.",
        "Define release steps and rollback strategy."
      ]
    },
    {
      "task_id": "wf_final_delivery",
      "title": "Prepare final delivery package for stakeholders",
      "owner_role": "e2e_mgr_product_owner",
      "dependencies": ["wf_quality_release"],
      "artifacts": ["delivery/01_final_delivery_package.md", "src/android/build.bat"],
      "acceptance": [
        "Summarize final scope, quality status, and release readiness.",
        "Provide final handoff package with clear next actions.",
        "Final delivery must be completed only after quality/release dependency is DONE."
      ]
    }
  ],
  "code_output_requirements": [
