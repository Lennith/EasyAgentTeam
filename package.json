{
  "name": "auto-develop-framework",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev:server": "pnpm --filter @autodev/server dev",
    "dev:web": "pnpm --filter dashboard-v2 dev",
    "dev": "concurrently -k -n server,web -c cyan,magenta \"pnpm run dev:server\" \"pnpm run dev:web\"",
    "dev:legacy": "concurrently -k -n server,web -c cyan,magenta \"npm --prefix server run dev\" \"npm --prefix dashboard-v2 run dev\"",
    "build": "pnpm --filter @autodev/agent-library build && pnpm --filter @autodev/server build && pnpm --filter dashboard-v2 build",
    "lint": "eslint server/src dashboard-v2/src agent_library/src tools --ext .ts,.tsx,.js,.mjs",
    "format": "prettier --write \"server/src/**/*.{ts,tsx,js,mjs,json}\" \"dashboard-v2/src/**/*.{ts,tsx,js,mjs,json,css}\" \"agent_library/src/**/*.{ts,tsx,js,mjs,json}\" \"tools/**/*.{ts,tsx,js,mjs}\" \"server/docs/**/*.md\" \"dashboard-v2/docs/**/*.md\" \"*.{md,json,yml,yaml}\"",
    "format:check": "prettier --check \"server/src/**/*.{ts,tsx,js,mjs,json}\" \"dashboard-v2/src/**/*.{ts,tsx,js,mjs,json,css}\" \"agent_library/src/**/*.{ts,tsx,js,mjs,json}\" \"tools/**/*.{ts,tsx,js,mjs}\" \"server/docs/**/*.md\" \"dashboard-v2/docs/**/*.md\" \"*.{md,json,yml,yaml}\"",
    "docs:check": "node tools/docs_check.mjs",
    "doctor": "node tools/doctor.mjs",
    "healthcheck": "node tools/healthcheck.mjs",
    "check:boundaries": "node tools/check-boundaries.mjs",
    "check:boundaries:strict": "node tools/check-boundaries.mjs --strict",
    "test": "pnpm test:smoke && pnpm test:unit",
    "test:smoke": "node tools/check_schemas.mjs",
    "test:api": "node tools/verify_dev.mjs",
    "test:step1": "node tools/verify_step1.mjs",
    "test:step2": "node tools/verify_step2.mjs",
    "test:step3": "node tools/verify_step3.mjs",
    "test:step4": "node tools/verify_step4.mjs",
    "test:step5": "node tools/verify_step5.mjs",
    "test:step6": "node tools/verify_step6.mjs",
    "test:unit": "pnpm --filter @autodev/server test",
    "e2e:first-run": "node tools/run-powershell-entry.mjs ./tools/run-first-run.ps1",
    "e2e:standard": "node tools/run-powershell-entry.mjs ./E2ETest/scripts/run-standard-e2e.ps1",
    "e2e:discuss": "node tools/run-powershell-entry.mjs ./E2ETest/scripts/run-discuss-e2e.ps1",
    "e2e:workflow": "node tools/run-powershell-entry.mjs ./E2ETest/scripts/run-workflow-e2e.ps1",
    "e2e:external-agent-3dof": "node tools/run-powershell-entry.mjs ./E2ETest/scripts/run-external-agent-3dof-e2e.ps1",
    "e2e:template-agent": "node tools/run-powershell-entry.mjs ./E2ETest/scripts/run-template-agent-e2e.ps1",
    "e2e:template-agent:cleanup:dry": "node E2ETest/scripts/cleanup-template-agent-test-data.mjs",
    "e2e:template-agent:cleanup": "node E2ETest/scripts/cleanup-template-agent-test-data.mjs --confirm",
    "e2e:baseline": "node tools/run-powershell-entry.mjs ./E2ETest/scripts/run-multi-e2e.ps1",
    "gate:standard": "node tools/run-powershell-entry.mjs ./tools/run-standard-gate.ps1",
    "gate:index": "node tools/generate-gate-doc-index.mjs",
    "agent-workspace": "node agent-workspace/cli.mjs",
    "agent-workspace:campaign": "node agent-workspace/campaign/run-campaign.mjs",
    "agent-workspace:campaign:dry": "node agent-workspace/campaign/run-campaign.mjs --dry-run",
    "agent-workspace:real-two-rounds": "node agent-workspace/supervisor/run-two-rounds-real.mjs",
    "agent-workspace:drive-run": "node agent-workspace/supervisor/drive-run-to-finished.mjs",
    "test:agent-workspace": "node --import tsx --test agent-workspace/tests/*.test.mjs",
    "mock:report": "node --import tsx tools/mock_report.ts",
    "mock:lock": "node --import tsx tools/mock_lock.ts",
    "mock:workflow": "node --import tsx tools/mock_workflow.ts",
    "mock:session": "node --import tsx tools/mock_session.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "concurrently": "^9.0.1",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.13.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tsx": "^4.20.5",
    "typescript-eslint": "^8.17.0"
  },
  "lint-staged": {
    "*.{md,json,yml,yaml,css}": [
      "prettier --write"
    ],
    "{server,dashboard-v2,agent_library,tools}/**/*.{ts,tsx,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
