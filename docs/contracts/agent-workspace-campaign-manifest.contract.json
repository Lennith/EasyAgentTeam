{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://easyagentteam.local/contracts/agent-workspace-campaign-manifest.contract.json",
  "title": "Agent Workspace Campaign Manifest Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "campaign_id", "name", "scenarios"],
  "properties": {
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "campaign_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "kind", "domain", "title", "goal"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": ["project", "workflow"]
          },
          "domain": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "workflow_min_steps": {
            "type": "integer",
            "minimum": 3
          },
          "run_workflow": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
