{
  "demo_id": "workflow_mode_demo_v1",
  "team_id": "demo_team_workflow_v1",
  "team_name": "Demo Team Workflow v1",
  "template_id": "demo_workflow_template_v1",
  "workflow_name": "Workflow Mode Official Demo",
  "workspace_path": "D:\\AgentWorkSpace\\EasyAgentTeam\\WorkflowModeDemo",
  "run_id_prefix": "demo_workflow_run_v1",
  "agents": [
    {
      "agent_id": "wf_planner",
      "display_name": "Workflow Planner",
      "prompt": "You are the workflow planner. Keep outputs concise and report phase completion with artifact evidence.",
      "provider_id": "minimax",
      "default_model_params": {
        "model": "MiniMax-Text-01",
        "effort": "medium"
      }
    },
    {
      "agent_id": "wf_executor",
      "display_name": "Workflow Executor",
      "prompt": "You are the workflow executor. Complete tasks and leave clear artifacts under docs/demo/workflow.",
      "provider_id": "minimax",
      "default_model_params": {
        "model": "MiniMax-Text-01",
        "effort": "medium"
      }
    }
  ],
  "route_table": {
    "wf_planner": ["wf_executor"],
    "wf_executor": ["wf_planner"]
  },
  "task_assign_route_table": {
    "wf_planner": ["wf_executor"],
    "wf_executor": ["wf_planner"]
  },
  "route_discuss_rounds": {
    "wf_planner": {
      "wf_executor": 2
    },
    "wf_executor": {
      "wf_planner": 2
    }
  },
  "tasks": [
    {
      "task_id": "wf_plan",
      "title": "Planning Phase",
      "owner_role": "wf_planner",
      "dependencies": [],
      "acceptance": ["A concise plan note exists in docs/demo/workflow/plan.md"],
      "artifacts": ["docs/demo/workflow/plan.md"]
    },
    {
      "task_id": "wf_execute",
      "title": "Execution Phase",
      "owner_role": "wf_executor",
      "dependencies": ["wf_plan"],
      "acceptance": ["Execution note exists in docs/demo/workflow/execution.md"],
      "artifacts": ["docs/demo/workflow/execution.md"]
    }
  ],
  "dispatch_target": {
    "role": "wf_planner",
    "task_id": "wf_plan"
  },
  "success_evidence": [
    "Workflow task runtime shows wf_plan and wf_execute in DONE state",
    "Workflow timeline/events contain ORCHESTRATOR_DISPATCH_STARTED",
    "Workflow timeline/events contain TASK_REPORT_APPLIED",
    "Workspace contains docs/demo/workflow/run_summary.md"
  ]
}
